---
import { Image } from "astro:assets"
import ArmandImage from "../assets/armand.jpeg"
import SocialLinks from "./SocialLinks.astro"
import SectionTitle from "./SectionTitle.astro"
import WorkTag from "./WorkTag.astro"
import { homeContent } from "../data/home"
---

<header class="flex flex-col gap-8">
  <div class="flex items-center gap-4">
    <div
      class="relative flex size-24 shrink-0 overflow-hidden rounded-full border border-white shadow-md shadow-slate-200"
    >
      <Image
        alt="Armand"
        class="block aspect-square h-full w-full object-cover"
        loading="eager"
        src={ArmandImage}
      />
    </div>
    <div class="space-y-2">
      <div>
        <h1 class="flex scroll-m-20 text-2xl font-semibold tracking-tight">
          {homeContent.hero.name}
        </h1>
        <div class="space-y-1 text-sm text-slate-500">
          <p class="font-medium text-slate-700">{homeContent.hero.title}</p>
          <p>{homeContent.hero.location}</p>
        </div>
      </div>
      <WorkTag />
    </div>
  </div>

  <section class="space-y-2">
    <div class="flex flex-col gap-4">
      <ul class="flex flex-wrap gap-2">
        {
          homeContent.hero.details.map((detail) => (
            <li class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-600 shadow-sm">
              {detail}
            </li>
          ))
        }
      </ul>

      <SectionTitle>About</SectionTitle>
      {
        homeContent.about.map((paragraph) => (
          <p class="max-w-3xl leading-7 text-slate-600">{paragraph}</p>
        ))
      }

      <SocialLinks />
    </div>
  </section>
</header>
