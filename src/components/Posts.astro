---
import { getCollection } from "astro:content"
import SectionTitle from "./SectionTitle.astro"
import PostPreview from "./PostPreview.astro"
import { homeContent } from "../data/home"

const allBlogPosts = await getCollection("post")
---

<article class="flex flex-col gap-4">
  <SectionTitle>{homeContent.writing.title}</SectionTitle>
  <div class="flex flex-col gap-2">
    <p class="max-w-2xl leading-7 text-slate-500">{homeContent.writing.intro}</p>
    <a
      class="inline-flex w-fit items-center rounded-full border border-slate-300 px-3 py-1 text-sm font-medium text-slate-600 transition hover:border-slate-500 hover:text-slate-900"
      href="/rss.xml"
      target="_blank"
      rel="noopener noreferrer"
    >
      RSS feed
    </a>
  </div>

  {
    allBlogPosts
      .sort((a, b) => b.data.pubDate.localeCompare(a.data.pubDate))
      .map((post) => (
        <PostPreview
          href={`/post/${post.slug}`}
          date={post.data.pubDate}
          title={post.data.title}
          description={post.data.description}
        />
      ))
  }
</article>
