---
import SectionTitle from "./SectionTitle.astro"
import { homeContent } from "../data/home"

const featuredWork = homeContent.selectedWork.filter((item) => item.featured)
const supportingWork = homeContent.selectedWork.filter((item) => !item.featured)
---

<section class="rounded-[2rem] bg-zinc-100 p-6 md:p-8">
  <div class="max-w-3xl">
    <SectionTitle>Selected work</SectionTitle>
    <p class="mt-2 leading-7 text-slate-500">
      A few projects and product environments that reflect how I work today:
      close to users, comfortable with complexity, and focused on shipping
      thoughtful systems.
    </p>
  </div>

  <div class="mt-6 grid gap-4 xl:grid-cols-3">
    {
      featuredWork.map((item) => (
        <article class="flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70">
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-1">
              <h4 class="text-lg font-semibold tracking-tight text-slate-900">
                {item.title}
              </h4>
              <p class="text-sm font-medium text-slate-600">{item.role}</p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-500">
              {item.period}
            </span>
          </div>

          <div class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
            {item.summary.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <ul class="mt-5 space-y-2 text-sm leading-6 text-slate-700">
            {item.highlights.map((highlight) => (
              <li>• {highlight}</li>
            ))}
          </ul>

          <ul class="mt-5 flex flex-wrap gap-2">
            {item.stack.map((technology) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                {technology}
              </li>
            ))}
          </ul>

          {item.link ? (
            <div class="mt-6 pt-2">
              <a
                href={item.link.href}
                target="_blank"
                class="inline-flex items-center gap-2 rounded-sm text-sm font-medium text-slate-700 outline-none transition hover:text-slate-950 focus-visible:ring-2 focus-visible:ring-slate-500 focus-visible:ring-offset-2"
              >
                {item.link.label}
                <i data-lucide="external-link" class="size-4 text-slate-400" />
              </a>
            </div>
          ) : null}
        </article>
      ))
    }
  </div>

  {
    supportingWork.length > 0 ? (
      <div class="mt-4 grid gap-4">
        {supportingWork.map((item) => (
          <article class="rounded-3xl border border-slate-200 bg-white/70 p-6 shadow-sm shadow-slate-200/60 backdrop-blur">
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div class="max-w-3xl">
                <div class="flex flex-wrap items-center gap-2">
                  <h4 class="text-lg font-semibold tracking-tight text-slate-900">
                    {item.title}
                  </h4>
                  <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                    Secondary proof
                  </span>
                </div>
                <p class="mt-1 text-sm font-medium text-slate-600">
                  {item.role} · {item.period}
                </p>
                <div class="mt-3 space-y-3 text-sm leading-7 text-slate-600">
                  {item.summary.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>

              {item.link ? (
                <a
                  href={item.link.href}
                  target="_blank"
                  class="inline-flex items-center gap-2 rounded-sm text-sm font-medium text-slate-700 outline-none transition hover:text-slate-950 focus-visible:ring-2 focus-visible:ring-slate-500 focus-visible:ring-offset-2"
                >
                  {item.link.label}
                  <i
                    data-lucide="external-link"
                    class="size-4 text-slate-400"
                  />
                </a>
              ) : null}
            </div>

            <ul class="mt-5 space-y-2 text-sm leading-6 text-slate-700">
              {item.highlights.map((highlight) => (
                <li>• {highlight}</li>
              ))}
            </ul>

            <ul class="mt-5 flex flex-wrap gap-2">
              {item.stack.map((technology) => (
                <li class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-sm">
                  {technology}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    ) : null
  }
</section>
